{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://codeflow.dev/schemas/project.schema.json",
  "title": "CodeFlow Project Configuration",
  "description": "Schema for .codeflow/project.yaml",
  "type": "object",
  "required": ["metadata", "orchestrator"],
  "properties": {
    "metadata": {
      "type": "object",
      "required": ["version", "project_name"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+$",
          "description": "Schema version"
        },
        "project_name": {
          "type": "string",
          "minLength": 1,
          "maxLength": 100,
          "description": "Project name"
        },
        "created_at": {
          "type": "string",
          "format": "date-time"
        },
        "last_modified": {
          "type": "string",
          "format": "date-time"
        },
        "owner": {
          "type": "string"
        }
      }
    },
    "orchestrator": {
      "type": "object",
      "required": ["version", "mode"],
      "properties": {
        "version": {
          "type": "string",
          "pattern": "^\\d+\\.\\d+\\.\\d+$"
        },
        "mode": {
          "type": "string",
          "enum": ["parallel", "sequential", "hybrid"],
          "default": "parallel"
        },
        "max_concurrent_agents": {
          "type": "integer",
          "minimum": 1,
          "maximum": 10,
          "default": 3
        },
        "max_concurrent_tasks": {
          "type": "integer",
          "minimum": 1,
          "maximum": 20,
          "default": 5
        },
        "conflict_resolution": {
          "type": "string",
          "enum": ["crdt", "manual", "priority-based"],
          "default": "crdt"
        }
      }
    },
    "workspace": {
      "type": "object",
      "properties": {
        "root_dir": {
          "type": "string"
        },
        "git_enabled": {
          "type": "boolean",
          "default": true
        },
        "git_branch_per_task": {
          "type": "boolean",
          "default": true
        },
        "auto_commit_threshold": {
          "type": "integer",
          "minimum": 1,
          "description": "Minutes between auto-commits"
        }
      }
    },
    "integrations": {
      "type": "object",
      "properties": {
        "github": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "owner": { "type": "string" },
            "repo": { "type": "string" },
            "api_token": { "type": "string" }
          }
        },
        "slack": {
          "type": "object",
          "properties": {
            "enabled": { "type": "boolean" },
            "webhook_url": { "type": "string" },
            "notify_on": {
              "type": "array",
              "items": {
                "type": "string",
                "enum": ["task_complete", "conflict", "error", "agent_disconnected"]
              }
            }
          }
        }
      }
    },
    "plugins": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "type", "command"],
        "properties": {
          "name": { "type": "string" },
          "type": {
            "type": "string",
            "enum": ["pre-execution", "post-execution", "on-conflict"]
          },
          "command": { "type": "string" }
        }
      }
    }
  }
}
